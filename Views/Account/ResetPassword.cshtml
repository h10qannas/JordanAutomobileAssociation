@model JAA.ViewModels.ResetPasswordViewModel
@{ Layout = "_Layout"; ViewData["Title"] = L["RP.Title"].Value;
   var jsTooShort = L["RP.TooShort"].Value;
   var jsWeak     = L["RP.Weak"].Value;
   var jsFair     = L["RP.Fair"].Value;
   var jsGood     = L["RP.Good"].Value;
   var jsStrong   = L["RP.Strong"].Value;
}

@section Styles {
<style>
.auth-page {
  min-height: 100vh; display: flex; align-items: center; justify-content: center;
  padding: 90px 1rem 3rem; position: relative; overflow: hidden; background: var(--dark);
}
.auth-page::before {
  content: ''; position: fixed; top: -160px; right: -160px;
  width: 520px; height: 520px;
  background: radial-gradient(circle, rgba(230,57,70,.13) 0%, transparent 65%);
  border-radius: 50%; pointer-events: none; z-index: 0;
}
.auth-page::after {
  content: ''; position: fixed; bottom: -120px; left: -120px;
  width: 420px; height: 420px;
  background: radial-gradient(circle, rgba(88,166,255,.07) 0%, transparent 65%);
  border-radius: 50%; pointer-events: none; z-index: 0;
}
.auth-wrap  { width: 100%; max-width: 420px; position: relative; z-index: 1; }
.auth-back  { display: inline-flex; align-items: center; gap: .4rem; color: var(--muted); font-size: .78rem; text-decoration: none; margin-bottom: 1.25rem; transition: color .2s; }
.auth-back:hover { color: var(--light); }
.auth-card  { background: var(--card); border: 1px solid var(--border); border-radius: 20px; padding: 2.5rem 2.25rem 2rem; box-shadow: 0 0 0 1px rgba(230,57,70,.06), 0 24px 64px rgba(0,0,0,.55); }
.ac-brand   { display: flex; align-items: center; justify-content: center; margin-bottom: 1.5rem; }
.ac-brand-logo { width: 48px; height: 48px; background: var(--red); border-radius: 14px; display: flex; align-items: center; justify-content: center; font-size: 1.15rem; font-weight: 900; color: #fff; letter-spacing: -1px; box-shadow: 0 6px 20px rgba(230,57,70,.35); }
.ac-title   { font-size: 1.45rem; font-weight: 800; color: var(--white); text-align: center; margin-bottom: .3rem; letter-spacing: -.4px; }
.ac-sub     { font-size: .83rem; color: var(--muted); text-align: center; margin-bottom: 1.9rem; }
.ac-divider { height: 1px; background: var(--border); margin: 0 -2.25rem 1.9rem; }
.field-wrap { margin-bottom: 1.15rem; }
.field-label { display: block; font-size: .72rem; font-weight: 700; color: var(--muted); text-transform: uppercase; letter-spacing: .6px; margin-bottom: .45rem; }
.field-box  { position: relative; }
.field-box .fi { position: absolute; left: .95rem; top: 50%; transform: translateY(-50%); color: var(--muted); font-size: .9rem; pointer-events: none; transition: color .2s; }
.field-box:focus-within .fi { color: var(--red); }
.field-in   { width: 100%; background: rgba(13,17,23,.7); border: 1px solid var(--border); border-radius: 10px; color: var(--white); font-size: .9rem; font-family: var(--font); padding: .75rem 2.8rem .75rem 2.65rem; transition: border-color .2s, box-shadow .2s; outline: none; }
.field-in:focus { border-color: var(--red); box-shadow: 0 0 0 3px rgba(230,57,70,.13); background: var(--dark); }
.field-in::placeholder { color: #3d444e; }
.field-toggle { position: absolute; right: .75rem; top: 50%; transform: translateY(-50%); background: none; border: none; cursor: pointer; color: var(--muted); font-size: .9rem; padding: .25rem; transition: color .2s; line-height: 1; }
.field-toggle:hover { color: var(--light); }
.field-err  { font-size: .72rem; color: #ff6b74; margin-top: .3rem; display: block; }
.btn-auth   { width: 100%; display: flex; align-items: center; justify-content: center; gap: .5rem; background: var(--red); color: #fff; border: none; border-radius: 10px; font-size: .95rem; font-weight: 700; font-family: var(--font); padding: .82rem; cursor: pointer; margin-top: .9rem; transition: background .2s, transform .15s, box-shadow .2s; letter-spacing: .1px; }
.btn-auth:hover { background: var(--red-d); transform: translateY(-1px); box-shadow: 0 8px 24px rgba(230,57,70,.35); }
.btn-auth:active { transform: translateY(0); box-shadow: none; }
.auth-alert { background: rgba(230,57,70,.08); border: 1px solid rgba(230,57,70,.2); border-radius: 10px; padding: .72rem .9rem; font-size: .8rem; color: #ff6b74; display: flex; align-items: flex-start; gap: .5rem; margin-bottom: 1.25rem; }

/* Password strength bar */
.pwd-strength { margin-top: .55rem; }
.pwd-strength-bar { height: 4px; background: var(--border); border-radius: 999px; overflow: hidden; margin-bottom: .3rem; }
.pwd-strength-fill { height: 100%; border-radius: 999px; width: 0; transition: width .3s, background .3s; }
.pwd-strength-label { font-size: .68rem; color: var(--muted); }
</style>
}

<div class="auth-page">
  <div class="auth-wrap">

    <a asp-action="ForgotPassword" class="auth-back">
      <i class="bi bi-arrow-left"></i> @L["RP.Back"]
    </a>

    <div class="auth-card">

      <div class="ac-brand">
        <div class="ac-brand-logo">JAA</div>
      </div>

      <div class="ac-title">@L["RP.Title"]</div>
      <div class="ac-sub">@L["RP.Sub"]</div>

      <div class="ac-divider"></div>

      @if (!ViewData.ModelState.IsValid)
      {
        <div class="auth-alert">
          <i class="bi bi-exclamation-circle-fill" style="flex-shrink:0;margin-top:.05rem;"></i>
          <div>@Html.ValidationSummary(true)</div>
        </div>
      }

      <form asp-action="ResetPassword" method="post" novalidate>
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="UserId" />
        <input type="hidden" asp-for="Token" />

        <div class="field-wrap">
          <label class="field-label">@L["RP.NewPassword"]</label>
          <div class="field-box">
            <i class="bi bi-lock-fill fi"></i>
            <input asp-for="NewPassword" class="field-in" placeholder="@L["RP.NewPasswordPlaceholder"].Value"
                   autocomplete="new-password" id="newPwd" oninput="checkStrength(this.value)" />
            <button type="button" class="field-toggle" onclick="togglePwd('newPwd','ico1')" tabindex="-1">
              <i class="bi bi-eye" id="ico1"></i>
            </button>
          </div>
          <div class="pwd-strength">
            <div class="pwd-strength-bar"><div class="pwd-strength-fill" id="strengthFill"></div></div>
            <div class="pwd-strength-label" id="strengthLabel"></div>
          </div>
          <span asp-validation-for="NewPassword" class="field-err"></span>
        </div>

        <div class="field-wrap">
          <label class="field-label">@L["RP.ConfirmPassword"]</label>
          <div class="field-box">
            <i class="bi bi-lock-fill fi"></i>
            <input asp-for="ConfirmPassword" class="field-in" placeholder="@L["RP.ConfirmPlaceholder"].Value"
                   autocomplete="new-password" id="cfmPwd" />
            <button type="button" class="field-toggle" onclick="togglePwd('cfmPwd','ico2')" tabindex="-1">
              <i class="bi bi-eye" id="ico2"></i>
            </button>
          </div>
          <span asp-validation-for="ConfirmPassword" class="field-err"></span>
        </div>

        <button type="submit" class="btn-auth">
          <i class="bi bi-check-circle-fill"></i> @L["RP.ResetButton"]
        </button>
      </form>

    </div>
  </div>
</div>

@section Scripts {
@await Html.PartialAsync("_ValidationScriptsPartial")
<script>
const _rp = {
  tooShort: '@Html.Raw(jsTooShort.Replace("'", "\\'"))',
  weak:     '@Html.Raw(jsWeak.Replace("'", "\\'"))',
  fair:     '@Html.Raw(jsFair.Replace("'", "\\'"))',
  good:     '@Html.Raw(jsGood.Replace("'", "\\'"))',
  strong:   '@Html.Raw(jsStrong.Replace("'", "\\'"))'
};

function togglePwd(inputId, iconId) {
  const inp = document.getElementById(inputId);
  const ico = document.getElementById(iconId);
  if (inp.type === 'password') { inp.type = 'text'; ico.className = 'bi bi-eye-slash'; }
  else { inp.type = 'password'; ico.className = 'bi bi-eye'; }
}

function checkStrength(val) {
  const fill  = document.getElementById('strengthFill');
  const label = document.getElementById('strengthLabel');
  if (!val) { fill.style.width = '0'; label.textContent = ''; return; }
  let score = 0;
  if (val.length >= 6)  score++;
  if (val.length >= 10) score++;
  if (/[A-Z]/.test(val)) score++;
  if (/[0-9]/.test(val)) score++;
  if (/[^A-Za-z0-9]/.test(val)) score++;
  const levels = [
    { w:'15%', color:'#e63946', text: _rp.tooShort },
    { w:'30%', color:'#e63946', text: _rp.weak     },
    { w:'55%', color:'var(--yellow-t)', text: _rp.fair },
    { w:'75%', color:'#58a6ff', text: _rp.good     },
    { w:'100%',color:'var(--green-t)',  text: _rp.strong },
  ];
  const l = levels[Math.min(score, 4)];
  fill.style.width      = l.w;
  fill.style.background = l.color;
  label.textContent     = l.text;
  label.style.color     = l.color;
}
</script>
}
