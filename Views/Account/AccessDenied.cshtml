@{ ViewData["Title"] = L["AD.Title"].Value; Layout = "_Layout"; }
<div style="min-height:80vh;display:flex;align-items:center;justify-content:center;text-align:center;padding:100px 1rem;">
  <div>
    <div style="width:80px;height:80px;background:rgba(230,57,70,.1);border:1px solid rgba(230,57,70,.3);border-radius:16px;display:flex;align-items:center;justify-content:center;font-size:2rem;color:var(--red);margin:0 auto 1.5rem;">
      <i class="bi bi-ban"></i>
    </div>
    <h1 style="font-size:1.8rem;font-weight:900;color:var(--white);margin-bottom:.5rem;">@L["AD.Title"]</h1>
    <p style="color:var(--muted);max-width:400px;margin:0 auto 1.5rem;">@L["AD.Desc"]</p>
    <a asp-controller="Home" asp-action="Index" class="btn-jaa btn-primary"><i class="bi bi-house-fill"></i> @L["AD.GoHome"]</a>
  </div>
</div>
