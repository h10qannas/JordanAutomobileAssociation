@model JAA.ViewModels.LoginViewModel
@{ Layout = "_Layout"; ViewData["Title"] = L["Login.SignInButton"].Value; }

@section Styles {
<style>
/* ── Page shell ── */
.auth-page {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 90px 1rem 3rem;
  position: relative;
  overflow: hidden;
  background: var(--dark);
}

/* decorative blobs */
.auth-page::before {
  content: '';
  position: fixed; top: -160px; right: -160px;
  width: 520px; height: 520px;
  background: radial-gradient(circle, rgba(230,57,70,.13) 0%, transparent 65%);
  border-radius: 50%; pointer-events: none; z-index: 0;
}
.auth-page::after {
  content: '';
  position: fixed; bottom: -120px; left: -120px;
  width: 420px; height: 420px;
  background: radial-gradient(circle, rgba(88,166,255,.07) 0%, transparent 65%);
  border-radius: 50%; pointer-events: none; z-index: 0;
}

/* ── Card ── */
.auth-wrap {
  width: 100%;
  max-width: 420px;
  position: relative;
  z-index: 1;
}

.auth-back {
  display: inline-flex; align-items: center; gap: .4rem;
  color: var(--muted); font-size: .78rem; text-decoration: none;
  margin-bottom: 1.25rem; transition: color .2s;
}
.auth-back:hover { color: var(--light); }

.auth-card {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 20px;
  padding: 2.5rem 2.25rem 2rem;
  box-shadow: 0 0 0 1px rgba(230,57,70,.06), 0 24px 64px rgba(0,0,0,.55);
}

/* brand inside card */
.ac-brand {
  display: flex; align-items: center; justify-content: center;
  margin-bottom: 1.5rem;
}
.ac-brand-logo {
  width: 48px; height: 48px;
  background: var(--red);
  border-radius: 14px;
  display: flex; align-items: center; justify-content: center;
  font-size: 1.15rem; font-weight: 900; color: #fff;
  letter-spacing: -1px;
  box-shadow: 0 6px 20px rgba(230,57,70,.35);
}

.ac-title {
  font-size: 1.45rem; font-weight: 800;
  color: var(--white); text-align: center;
  margin-bottom: .3rem; letter-spacing: -.4px;
}
.ac-sub {
  font-size: .83rem; color: var(--muted);
  text-align: center; margin-bottom: 1.9rem;
}

/* divider */
.ac-divider {
  height: 1px; background: var(--border);
  margin: 0 -2.25rem 1.9rem;
}

/* ── Fields ── */
.field-wrap { margin-bottom: 1.15rem; }

.field-label {
  display: block; font-size: .72rem; font-weight: 700;
  color: var(--muted); text-transform: uppercase;
  letter-spacing: .6px; margin-bottom: .45rem;
}

.field-box { position: relative; }

.field-box .fi {
  position: absolute; left: .95rem; top: 50%; transform: translateY(-50%);
  color: var(--muted); font-size: .9rem; pointer-events: none; transition: color .2s;
}
.field-box:focus-within .fi { color: var(--red); }

.field-in {
  width: 100%;
  background: rgba(13,17,23,.7);
  border: 1px solid var(--border);
  border-radius: 10px;
  color: var(--white); font-size: .9rem; font-family: var(--font);
  padding: .75rem 2.8rem .75rem 2.65rem;
  transition: border-color .2s, box-shadow .2s; outline: none;
}
.field-in:focus {
  border-color: var(--red);
  box-shadow: 0 0 0 3px rgba(230,57,70,.13);
  background: var(--dark);
}
.field-in::placeholder { color: #3d444e; }

.field-toggle {
  position: absolute; right: .75rem; top: 50%; transform: translateY(-50%);
  background: none; border: none; cursor: pointer;
  color: var(--muted); font-size: .9rem; padding: .25rem;
  transition: color .2s; line-height: 1;
}
.field-toggle:hover { color: var(--light); }

.field-err { font-size: .72rem; color: #ff6b74; margin-top: .3rem; display: block; }

/* ── Submit ── */
.btn-auth {
  width: 100%; display: flex; align-items: center; justify-content: center; gap: .5rem;
  background: var(--red); color: #fff; border: none; border-radius: 10px;
  font-size: .95rem; font-weight: 700; font-family: var(--font);
  padding: .82rem; cursor: pointer; margin-top: .9rem;
  transition: background .2s, transform .15s, box-shadow .2s;
  letter-spacing: .1px;
}
.btn-auth:hover {
  background: var(--red-d);
  transform: translateY(-1px);
  box-shadow: 0 8px 24px rgba(230,57,70,.35);
}
.btn-auth:active { transform: translateY(0); box-shadow: none; }

/* ── Footer link ── */
.auth-foot {
  text-align: center; font-size: .8rem;
  color: var(--muted); margin-top: 1.4rem;
}
.auth-foot a { color: var(--red); font-weight: 600; text-decoration: none; }
.auth-foot a:hover { text-decoration: underline; }

/* ── Error alert ── */
.auth-alert {
  background: rgba(230,57,70,.08);
  border: 1px solid rgba(230,57,70,.2);
  border-radius: 10px; padding: .72rem .9rem;
  font-size: .8rem; color: #ff6b74;
  display: flex; align-items: flex-start; gap: .5rem;
  margin-bottom: 1.25rem;
}
</style>
}

<div class="auth-page">
  <div class="auth-wrap">

    <a asp-controller="Home" asp-action="Index" class="auth-back">
      <i class="bi bi-arrow-left"></i> @L["Login.BackToHome"]
    </a>

    <div class="auth-card">

      <!-- Brand mark -->
      <div class="ac-brand">
        <div class="ac-brand-logo">JAA</div>
      </div>

      <div class="ac-title">@L["Login.WelcomeBack"]</div>
      <div class="ac-sub">@L["Login.SignInSub"]</div>

      <div class="ac-divider"></div>

      @if (Context.Request.Query.ContainsKey("pendingRequest"))
      {
        <div style="background:rgba(88,166,255,.1);border:1px solid rgba(88,166,255,.28);border-radius:10px;padding:.72rem .9rem;font-size:.82rem;color:#58a6ff;display:flex;align-items:flex-start;gap:.55rem;margin-bottom:1.25rem;">
          <i class="bi bi-info-circle-fill" style="flex-shrink:0;margin-top:.1rem;"></i>
          <div>@L["RH.PendingSignIn"]</div>
        </div>
      }

      @if (TempData["ResetSuccess"] != null)
      {
        <div style="background:rgba(35,134,54,.1);border:1px solid rgba(35,134,54,.28);border-radius:10px;padding:.72rem .9rem;font-size:.8rem;color:var(--green-t);display:flex;align-items:flex-start;gap:.5rem;margin-bottom:1.25rem;">
          <i class="bi bi-check-circle-fill" style="flex-shrink:0;margin-top:.05rem;"></i>
          <div>@TempData["ResetSuccess"]</div>
        </div>
      }

      @if (!ViewData.ModelState.IsValid)
      {
        <div class="auth-alert">
          <i class="bi bi-exclamation-circle-fill" style="flex-shrink:0;margin-top:.05rem;"></i>
          <div>@Html.ValidationSummary(true)</div>
        </div>
      }

      <form asp-action="Login" method="post" novalidate>
        @Html.AntiForgeryToken()
        <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />

        <div class="field-wrap">
          <label class="field-label">@L["Login.PhoneNumber"]</label>
          <div class="field-box">
            <i class="bi bi-telephone-fill fi"></i>
            <input asp-for="Identifier" class="field-in" placeholder="+962 7x xxx xxxx" autocomplete="tel" inputmode="tel" />
          </div>
          <span asp-validation-for="Identifier" class="field-err"></span>
        </div>

        <div class="field-wrap">
          <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:.45rem;">
            <label class="field-label" style="margin-bottom:0;">@L["Login.Password"]</label>
            <a asp-action="ForgotPassword" style="font-size:.72rem;color:var(--red);text-decoration:none;font-weight:600;">@L["Login.ForgotPassword"]</a>
          </div>
          <div class="field-box">
            <i class="bi bi-lock-fill fi"></i>
            <input asp-for="Password" class="field-in" placeholder="••••••••" autocomplete="current-password" id="pwdInput" />
            <button type="button" class="field-toggle" onclick="togglePwd()" tabindex="-1" aria-label="Show/hide password">
              <i class="bi bi-eye" id="pwdIcon"></i>
            </button>
          </div>
          <span asp-validation-for="Password" class="field-err"></span>
        </div>

        <button type="submit" class="btn-auth">
          <i class="bi bi-box-arrow-in-right"></i> @L["Login.SignInButton"]
        </button>
      </form>

      <div class="auth-foot">
        @L["Login.NoAccount"] <a asp-controller="Account" asp-action="Register" asp-route-returnUrl="@ViewData["ReturnUrl"]?.ToString()">@L["Login.CreateOne"]</a>
      </div>

    </div>
  </div>
</div>

@section Scripts {
<script>
function togglePwd() {
  const inp = document.getElementById('pwdInput');
  const ico = document.getElementById('pwdIcon');
  if (inp.type === 'password') { inp.type = 'text'; ico.className = 'bi bi-eye-slash'; }
  else { inp.type = 'password'; ico.className = 'bi bi-eye'; }
}
</script>
@await Html.PartialAsync("_ValidationScriptsPartial") }
