@model JAA.Models.ServiceRequest
@using JAA.Models
@{
    Layout = "_Layout";
    ViewData["Title"] = L["CP.Title"].Value;
    var verification   = Model.PaymentVerification!;
    var mechanicAmount = verification.MechanicReportedAmount;
}

@section Styles {
<style>
.cp-page { min-height: 100vh; padding: 90px 1rem 3rem; }

.cp-wrap { max-width: 560px; margin: 0 auto; }

.cp-back { display: inline-flex; align-items: center; gap: .4rem; color: var(--muted); font-size: .78rem; text-decoration: none; margin-bottom: 1.5rem; transition: color .2s; }
.cp-back:hover { color: var(--light); }

/* Header */
.cp-header {
    background: linear-gradient(135deg, var(--card) 0%, rgba(230,57,70,.04) 100%);
    border: 1px solid var(--border); border-radius: 20px;
    padding: 1.75rem 1.75rem; margin-bottom: 1.5rem;
    position: relative; overflow: hidden;
}
.cp-header::after {
    content: ''; position: absolute; top: -60px; right: -60px;
    width: 200px; height: 200px;
    background: radial-gradient(circle, rgba(230,57,70,.1) 0%, transparent 70%);
    border-radius: 50%;
}
.cp-hdr-inner { display: flex; align-items: center; gap: 1.1rem; position: relative; z-index: 1; }
.cp-hdr-icon {
    width: 56px; height: 56px; border-radius: 16px; flex-shrink: 0;
    background: rgba(230,57,70,.12); border: 1px solid rgba(230,57,70,.22);
    display: flex; align-items: center; justify-content: center;
    font-size: 1.4rem; color: var(--red);
}
.cp-hdr-title { font-size: 1.1rem; font-weight: 800; color: var(--white); margin-bottom: .25rem; }
.cp-hdr-sub   { font-size: .8rem; color: var(--muted); line-height: 1.5; }

/* Info chips */
.cp-chips { display: flex; gap: .6rem; flex-wrap: wrap; margin: 1rem 0 1.5rem; }
.cp-chip {
    display: inline-flex; align-items: center; gap: .45rem;
    background: rgba(255,255,255,.04); border: 1px solid var(--border);
    border-radius: 999px; font-size: .75rem; color: var(--muted); padding: .3rem .85rem;
}
.cp-chip strong { color: var(--light); }

/* Mechanic amount card */
.cp-mech-amount {
    background: rgba(63,185,80,.06); border: 1px solid rgba(63,185,80,.2);
    border-radius: 16px; padding: 1.25rem 1.5rem;
    display: flex; align-items: center; justify-content: space-between;
    gap: 1rem; margin-bottom: 1.5rem;
}
.cp-ma-label { font-size: .68rem; font-weight: 700; color: var(--muted); text-transform: uppercase; letter-spacing: .6px; margin-bottom: .2rem; }
.cp-ma-val   { font-size: 2rem; font-weight: 900; color: var(--white); letter-spacing: -2px; line-height: 1; }
.cp-ma-val span { font-size: .9rem; color: var(--muted); font-weight: 600; }
.cp-ma-ico {
    width: 50px; height: 50px; border-radius: 14px; flex-shrink: 0;
    background: rgba(63,185,80,.1); border: 1px solid rgba(63,185,80,.2);
    display: flex; align-items: center; justify-content: center;
    font-size: 1.25rem; color: var(--green-t,#3fb950);
}

/* Question / form card */
.cp-card {
    background: var(--card); border: 1px solid var(--border);
    border-radius: 18px; padding: 1.5rem 1.5rem; margin-bottom: 1.25rem;
}
.cp-question { font-size: 1rem; font-weight: 800; color: var(--white); margin-bottom: .35rem; letter-spacing: -.2px; }
.cp-hint     { font-size: .8rem; color: var(--muted); margin-bottom: 1.25rem; line-height: 1.55; }

.cp-field-wrap { position: relative; }
.cp-field-ico  { position: absolute; left: .9rem; top: 50%; transform: translateY(-50%); color: var(--muted); font-size: .9rem; pointer-events: none; transition: color .2s; }
.cp-field-wrap:focus-within .cp-field-ico { color: var(--red); }
.cp-in {
    width: 100%; background: rgba(13,17,23,.7); border: 1px solid var(--border);
    border-radius: 10px; color: var(--white); font-size: 1rem; font-weight: 700;
    font-family: var(--font); padding: .8rem 1rem .8rem 2.5rem;
    transition: border-color .2s, box-shadow .2s; outline: none;
}
.cp-in:focus { border-color: var(--red); box-shadow: 0 0 0 3px rgba(230,57,70,.12); background: var(--dark); }
.cp-in::placeholder { color: #3d444e; font-weight: 400; }

/* Dispute hint */
.cp-dispute-hint {
    font-size: .74rem; color: var(--muted); margin-top: .65rem;
    display: flex; align-items: center; gap: .4rem; line-height: 1.5;
}

/* Actions */
.btn-cp-confirm {
    width: 100%; display: flex; align-items: center; justify-content: center; gap: .5rem;
    background: var(--red); color: #fff; border: none; border-radius: 10px;
    font-size: .92rem; font-weight: 700; font-family: var(--font);
    padding: .82rem; cursor: pointer; margin-top: 1rem;
    transition: background .2s, transform .15s, box-shadow .2s;
}
.btn-cp-confirm:hover { background: var(--red-d); transform: translateY(-1px); box-shadow: 0 8px 24px rgba(230,57,70,.3); }

/* Guarantee note */
.cp-guarantee {
    background: rgba(88,166,255,.06); border: 1px solid rgba(88,166,255,.14);
    border-radius: 12px; padding: .9rem 1.1rem;
    display: flex; align-items: flex-start; gap: .7rem; font-size: .78rem; color: var(--muted); line-height: 1.6;
    margin-top: 1.25rem;
}
</style>
}

<div class="cp-page">
<div class="container cp-wrap">

  <a asp-action="TrackRequest" asp-route-id="@Model.Id" class="cp-back">
    <i class="bi bi-arrow-left"></i> @L["Track.Dashboard"]
  </a>

  <!-- Header -->
  <div class="cp-header">
    <div class="cp-hdr-inner">
      <div class="cp-hdr-icon"><i class="bi bi-shield-check"></i></div>
      <div>
        <div class="cp-hdr-title">@L["CP.Title"]</div>
        <div class="cp-hdr-sub">@L["CP.SubTitle"]</div>
      </div>
    </div>
    <div class="cp-chips">
      @if (Model.Shop != null)
      {
        <span class="cp-chip"><i class="bi bi-shop-window"></i> <strong>@Model.Shop.ShopName</strong></span>
      }
      @if (Model.Mechanic != null)
      {
        <span class="cp-chip"><i class="bi bi-wrench"></i> <strong>@Model.Mechanic.FullName</strong></span>
      }
      <span class="cp-chip"><i class="bi bi-hash"></i> <strong>Request #@Model.Id</strong></span>
    </div>
  </div>

  <!-- Mechanic reported amount -->
  <div class="cp-mech-amount">
    <div>
      <div class="cp-ma-label">@L["CP.MechanicReported"]</div>
      <div class="cp-ma-val">@mechanicAmount.ToString("F2") <span>JOD</span></div>
      @if (!string.IsNullOrEmpty(verification.MechanicNotes))
      {
        <div style="font-size:.75rem;color:var(--muted);margin-top:.4rem;font-style:italic;">"@verification.MechanicNotes"</div>
      }
    </div>
    <div class="cp-ma-ico"><i class="bi bi-receipt"></i></div>
  </div>

  <!-- Confirmation form -->
  <div class="cp-card">
    <div class="cp-question">@L["CP.HowMuchDidYouPay"]</div>
    <div class="cp-hint">@L["CP.HowMuchHint"]</div>

    <form asp-action="ConfirmPayment" asp-controller="Customer" method="post" novalidate>
      @Html.AntiForgeryToken()
      <input type="hidden" name="requestId" value="@Model.Id" />

      <div class="cp-field-wrap">
        <i class="bi bi-cash-stack cp-field-ico"></i>
        <input type="number" name="customerAmount" step="0.01" min="0.01"
               class="cp-in" placeholder="0.00" required
               autofocus />
      </div>

      <div class="cp-dispute-hint">
        <i class="bi bi-info-circle" style="flex-shrink:0;"></i>
        @L["CP.DisputeHint"]
      </div>

      <button type="submit" class="btn-cp-confirm">
        <i class="bi bi-check-circle-fill"></i> @L["CP.ConfirmButton"]
      </button>
    </form>
  </div>

  <div class="cp-guarantee">
    <i class="bi bi-shield-lock-fill" style="flex-shrink:0;color:var(--blue);font-size:1.1rem;margin-top:.1rem;"></i>
    <div>@L["CP.ProtectionNote"]</div>
  </div>

</div>
</div>
