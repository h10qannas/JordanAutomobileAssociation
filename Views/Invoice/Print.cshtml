@model JAA.Services.InvoiceData
@using JAA.Models
@{
    Layout = null;
    ViewData["Title"] = $"{L["Inv.Title"].Value} {Model.InvoiceNumber}";
}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>@Model.InvoiceNumber — JAA</title>
  <style>
    * { margin:0;padding:0;box-sizing:border-box; }
    body { font-family:'Segoe UI',Arial,sans-serif;font-size:13px;color:#1a1a1a;background:#fff;padding:30px; }
    .header { display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:30px;padding-bottom:20px;border-bottom:2px solid #e63946; }
    .brand { font-size:28px;font-weight:900;color:#1a1a1a; }
    .brand span { color:#e63946; }
    .brand-sub { font-size:11px;color:#6b7280;margin-top:2px; }
    .invoice-num { text-align:right; }
    .invoice-num .label { font-size:10px;font-weight:700;color:#6b7280;text-transform:uppercase;letter-spacing:.5px; }
    .invoice-num .num { font-size:18px;font-weight:800;color:#1a1a1a; }
    .invoice-num .date { font-size:11px;color:#6b7280; }
    .parties { display:grid;grid-template-columns:1fr 1fr 1fr;gap:20px;margin-bottom:28px; }
    .party-label { font-size:9px;font-weight:700;color:#6b7280;text-transform:uppercase;letter-spacing:.5px;margin-bottom:5px; }
    .party-name { font-size:13px;font-weight:700;color:#1a1a1a; }
    .party-detail { font-size:11px;color:#6b7280;margin-top:2px; }
    table { width:100%;border-collapse:collapse;margin-bottom:20px; }
    thead th { background:#f9fafb;border:1px solid #e5e7eb;padding:8px 12px;text-align:left;font-size:10px;font-weight:700;color:#6b7280;text-transform:uppercase;letter-spacing:.4px; }
    thead th:last-child { text-align:right; }
    tbody td { border:1px solid #e5e7eb;padding:9px 12px;font-size:12px;color:#374151; }
    tbody td:last-child { text-align:right;font-weight:600; }
    tfoot td { border:1px solid #e5e7eb;padding:10px 12px; }
    .total-row { background:#fff5f5; }
    .total-row td { font-size:14px;font-weight:800;color:#e63946; }
    .total-row td:last-child { text-align:right; }
    .footer { margin-top:30px;padding-top:15px;border-top:1px solid #e5e7eb;text-align:center;font-size:10px;color:#9ca3af; }
    @@media print {
      body { padding:15px; }
      .no-print { display:none; }
    }
  </style>
</head>
<body>
  <div class="header">
    <div>
      <div class="brand">JAA<span>.</span></div>
      <div class="brand-sub">@L["Inv.JordanAutoAssistance"] · support@jaa.jo · +962 6 000 0000</div>
    </div>
    <div class="invoice-num">
      <div class="label">@L["Inv.Title"]</div>
      <div class="num">@Model.InvoiceNumber</div>
      <div class="date">@Model.IssuedAt.ToLocalTime().ToString("dd MMMM yyyy")</div>
    </div>
  </div>

  <div class="parties">
    <div>
      <div class="party-label">@L["Inv.Customer"]</div>
      <div class="party-name">@Model.CustomerName</div>
      <div class="party-detail">@Model.CustomerPhone</div>
    </div>
    <div>
      <div class="party-label">@L["Inv.Shop"]</div>
      <div class="party-name">@Model.ShopName</div>
      <div class="party-detail">@Model.ShopCity · @Model.ShopPhone</div>
    </div>
    <div>
      <div class="party-label">@L["Inv.Mechanic"]</div>
      <div class="party-name">@(string.IsNullOrEmpty(Model.MechanicName) ? "—" : Model.MechanicName)</div>
      <div class="party-detail">@Model.MechanicPhone</div>
    </div>
  </div>

  <table>
    <thead>
      <tr>
        <th>@L["Inv.Description"]</th>
        <th>@L["Inv.PaymentMethod"]</th>
        <th>@L["Inv.Status"]</th>
        <th>@L["Inv.AmountJOD"]</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td>@L["Inv.InspectionFee"]</td>
        <td>@Model.InspectionMethod</td>
        <td>@Model.InspectionStatus</td>
        <td>@Model.InspectionAmount.ToString("F2")</td>
      </tr>
      @if (Model.HasRepairPayment)
      {
        <tr>
          <td>@L["Inv.RepairAmount"]</td>
          <td>@Model.RepairMethod</td>
          <td>@Model.RepairStatus</td>
          <td>@Model.RepairTotalAmount.ToString("F2")</td>
        </tr>
      }
    </tbody>
    <tfoot>
      <tr class="total-row">
        <td colspan="3"><strong>@L["Inv.TotalAmountDue"]</strong></td>
        <td><strong>@Model.GrandTotal.ToString("F2") JOD</strong></td>
      </tr>
    </tfoot>
  </table>

  <div class="footer">
    Request #@Model.Request.Id · @Model.InvoiceNumber · Generated @DateTime.Now.ToString("dd MMM yyyy HH:mm") ·
    JAA — @L["Inv.JordanAutoAssistance"] · All rights reserved.
  </div>

  <div class="no-print" style="text-align:center;margin-top:25px;">
    <button onclick="window.print()" style="background:#e63946;color:#fff;border:none;padding:10px 24px;border-radius:8px;font-size:14px;font-weight:700;cursor:pointer;">
      🖨️ @L["Inv.PrintSavePdf"]
    </button>
    <button onclick="window.close()" style="background:#f3f4f6;color:#374151;border:1px solid #d1d5db;padding:10px 24px;border-radius:8px;font-size:14px;font-weight:600;cursor:pointer;margin-left:10px;">
      @L["Inv.Close"]
    </button>
  </div>
</body>
</html>
