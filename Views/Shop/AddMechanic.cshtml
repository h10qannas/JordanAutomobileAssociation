@model JAA.ViewModels.AddMechanicViewModel
@{ Layout = "_DashboardLayout"; ViewData["Title"] = L["ShopMech.AddMechanic"].Value; ViewData["PageTitle"] = L["ShopMech.AddMechanic"].Value; ViewData["PageSub"] = L["ShopAM.PageSub"].Value; }

<div class="row justify-content-center">
  <div class="col-lg-6">
    <div class="card-jaa">
      <form asp-action="AddMechanic" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()

        <div class="mb-4">
          <label class="form-label-jaa" asp-for="FullName"></label>
          <input asp-for="FullName" class="form-control-jaa" />
          <span asp-validation-for="FullName" class="val-msg"></span>
        </div>

        <div class="mb-4">
          <label class="form-label-jaa" asp-for="NationalId"></label>
          <input asp-for="NationalId" class="form-control-jaa" />
          <span asp-validation-for="NationalId" class="val-msg"></span>
        </div>

        <div class="mb-4">
          <label class="form-label-jaa" asp-for="PhoneNumber"></label>
          <input asp-for="PhoneNumber" class="form-control-jaa" />
          <span asp-validation-for="PhoneNumber" class="val-msg"></span>
        </div>

        <div class="mb-4">
          <label class="form-label-jaa" asp-for="YearsOfExperience"></label>
          <input asp-for="YearsOfExperience" type="number" min="0" max="60" class="form-control-jaa" />
          <span asp-validation-for="YearsOfExperience" class="val-msg"></span>
        </div>

        <div class="mb-4">
          <label class="form-label-jaa">@L["ShopAM.ProfilePhoto"]</label>
          <input asp-for="ProfileImage" type="file" accept="image/*" class="form-control-jaa" />
        </div>

        <div style="background:rgba(255,193,7,.06);border:1px solid rgba(255,193,7,.2);border-radius:10px;padding:.8rem 1rem;margin-bottom:1.3rem;font-size:.78rem;color:#f59e0b;">
          <i class="bi bi-info-circle me-1"></i>
          @L["ShopAM.PendingNote"]
        </div>

        <div class="d-flex gap-3">
          <button type="submit" class="btn-jaa btn-primary flex-grow-1">
            <i class="bi bi-person-plus-fill"></i> @L["ShopAM.SubmitForApproval"]
          </button>
          <a asp-action="Mechanics" class="btn-jaa btn-ghost">@L["ShopAM.Cancel"]</a>
        </div>
      </form>
    </div>
  </div>
</div>

@section Scripts {
  @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
