@model List<JAA.Models.PaymentVerification>
@using JAA.Models
@{
    ViewData["Title"]    = "Payment Verifications";
    ViewData["PageTitle"] = "Payment Verifications";
    ViewData["PageSub"]  = "Disputed and pending repair amount confirmations";

    var pending    = Model.Where(v => v.Status == VerificationStatus.Pending).ToList();
    var flagged    = Model.Where(v => v.Status is VerificationStatus.Flagged or VerificationStatus.UnderReview).ToList();
    var resolved   = Model.Where(v => v.Status == VerificationStatus.Resolved).ToList();
    var verified   = Model.Where(v => v.Status == VerificationStatus.Verified).ToList();
}

@section Styles {
<style>
.pv-stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; margin-bottom: 1.5rem; }
@@media(max-width:640px){ .pv-stats { grid-template-columns: 1fr 1fr; } }

.pv-card {
    background: var(--card); border: 1px solid var(--border);
    border-radius: 16px; overflow: hidden; margin-bottom: 1.25rem;
}
.pv-card-head {
    display: flex; align-items: center; justify-content: space-between;
    padding: .9rem 1.25rem; border-bottom: 1px solid var(--border);
    font-size: .88rem; font-weight: 700; color: var(--white);
}
.pv-badge {
    display: inline-flex; align-items: center; gap: .3rem;
    border-radius: 999px; font-size: .63rem; font-weight: 700;
    padding: .22rem .7rem; text-transform: uppercase; letter-spacing: .4px;
}
.pvb-pending  { background:rgba(210,153,34,.12); color:var(--yellow-t); border:1px solid rgba(210,153,34,.25); }
.pvb-flagged  { background:rgba(230,57,70,.1);   color:var(--red);      border:1px solid rgba(230,57,70,.25); }
.pvb-verified { background:rgba(63,185,80,.1);   color:var(--green-t);  border:1px solid rgba(63,185,80,.25); }
.pvb-resolved { background:rgba(88,166,255,.1);  color:var(--blue);     border:1px solid rgba(88,166,255,.2); }

.pv-row {
    display: grid; grid-template-columns: 60px 1fr 1fr 100px 100px 100px 130px 160px;
    align-items: center; gap: .75rem;
    padding: .85rem 1.25rem; border-bottom: 1px solid var(--border);
    transition: background .15s;
}
.pv-row:last-child { border-bottom: none; }
.pv-row:hover { background: rgba(255,255,255,.02); }
.pv-col-hd { font-size: .65rem; font-weight: 700; color: var(--muted); text-transform: uppercase; letter-spacing: .5px; }
.pv-id   { font-size: .82rem; font-weight: 800; color: var(--white); }
.pv-name { font-size: .84rem; font-weight: 600; color: var(--white); }
.pv-sub  { font-size: .72rem; color: var(--muted); }
.pv-amt  { font-size: .92rem; font-weight: 800; }
.pv-amt-green { color: var(--green-t); }
.pv-amt-red   { color: var(--red); }
.pv-amt-blue  { color: var(--blue); }
.pv-diff { font-size: .82rem; font-weight: 700; }
.pv-diff-neg { color: var(--red); }
.pv-diff-pos { color: var(--green-t); }

/* Resolve modal */
.pv-modal-overlay {
    display: none; position: fixed; inset: 0; z-index: 9999;
    background: rgba(0,0,0,.65); backdrop-filter: blur(4px);
    align-items: center; justify-content: center;
}
.pv-modal-overlay.open { display: flex; }
.pv-modal {
    background: var(--card); border: 1px solid var(--border);
    border-radius: 20px; padding: 2rem; max-width: 520px; width: 94%;
    box-shadow: 0 24px 60px rgba(0,0,0,.5);
}
.pv-modal-title { font-size: 1rem; font-weight: 800; color: var(--white); margin-bottom: 1.25rem; }
.pv-modal-row   { display: flex; justify-content: space-between; padding: .6rem 0; border-bottom: 1px solid var(--border); font-size: .84rem; }
.pv-modal-row:last-of-type { border-bottom: none; }
.pv-modal-lbl   { color: var(--muted); }
.pv-modal-val   { color: var(--white); font-weight: 700; }

.pv-res-opts { margin: 1.1rem 0; }
.pv-res-opt {
    display: flex; align-items: center; gap: .75rem;
    padding: .8rem 1rem; border: 1px solid var(--border);
    border-radius: 10px; margin-bottom: .5rem; cursor: pointer;
    transition: border-color .2s, background .2s;
}
.pv-res-opt:has(input:checked) { border-color: var(--red); background: rgba(230,57,70,.04); }
.pv-res-opt input { accent-color: var(--red); }
.pv-res-opt-label { font-size: .84rem; font-weight: 600; color: var(--white); }
.pv-res-opt-sub   { font-size: .72rem; color: var(--muted); }
.pv-manual-field  { display: none; margin-top: .5rem; }
.pv-manual-in {
    width: 100%; background: rgba(13,17,23,.7); border: 1px solid var(--border);
    border-radius: 8px; color: var(--white); font-size: .88rem; font-family: var(--font);
    padding: .6rem .85rem; outline: none; transition: border-color .2s;
}
.pv-manual-in:focus { border-color: var(--red); }
.pv-notes-in {
    width: 100%; background: rgba(13,17,23,.7); border: 1px solid var(--border);
    border-radius: 8px; color: var(--white); font-size: .84rem; font-family: var(--font);
    padding: .6rem .85rem; outline: none; margin-top: .85rem;
    transition: border-color .2s; resize: vertical;
}
.pv-notes-in:focus { border-color: var(--red); }

.pv-modal-actions { display: flex; gap: .75rem; margin-top: 1.1rem; }
.btn-pv-resolve {
    flex: 1; display: flex; align-items: center; justify-content: center; gap: .5rem;
    background: var(--red); color: #fff; border: none; border-radius: 10px;
    font-size: .88rem; font-weight: 700; font-family: var(--font); padding: .72rem;
    cursor: pointer; transition: background .2s;
}
.btn-pv-resolve:hover { background: var(--red-d); }
.btn-pv-close {
    display: flex; align-items: center; justify-content: center; gap: .4rem;
    background: rgba(255,255,255,.04); border: 1px solid var(--border);
    color: var(--muted); border-radius: 10px; font-size: .85rem;
    padding: .72rem 1.1rem; cursor: pointer; transition: background .2s;
    font-family: var(--font);
}
.btn-pv-close:hover { background: rgba(255,255,255,.08); color: var(--light); }

@@media(max-width:900px) {
    .pv-row { grid-template-columns: 50px 1fr 1fr 80px 80px 80px; }
    .pv-row .pv-col-actions { grid-column: 1 / -1; }
}
</style>
}

<!-- Stats -->
<div class="pv-stats">
  <div class="stat-card">
    <div class="stat-icon stat-icon-yellow"><i class="bi bi-hourglass-split"></i></div>
    <div><div class="stat-num">@pending.Count</div><div class="stat-label">Awaiting Customer</div></div>
  </div>
  <div class="stat-card">
    <div class="stat-icon stat-icon-red"><i class="bi bi-exclamation-triangle-fill"></i></div>
    <div><div class="stat-num">@flagged.Count</div><div class="stat-label">Disputes</div></div>
  </div>
  <div class="stat-card">
    <div class="stat-icon stat-icon-green"><i class="bi bi-shield-check"></i></div>
    <div><div class="stat-num">@verified.Count</div><div class="stat-label">Verified</div></div>
  </div>
  <div class="stat-card">
    <div class="stat-icon stat-icon-blue"><i class="bi bi-check2-circle"></i></div>
    <div><div class="stat-num">@resolved.Count</div><div class="stat-label">Resolved</div></div>
  </div>
</div>

@if (!flagged.Any() && !pending.Any())
{
  <div class="card-jaa" style="text-align:center;padding:3rem 1.5rem;">
    <div style="width:60px;height:60px;margin:0 auto 1rem;background:rgba(63,185,80,.08);border:1px solid rgba(63,185,80,.15);border-radius:16px;display:flex;align-items:center;justify-content:center;font-size:1.5rem;color:var(--green-t);">
      <i class="bi bi-shield-check"></i>
    </div>
    <div style="font-size:.95rem;font-weight:700;color:var(--white);margin-bottom:.35rem;">All Clear</div>
    <div style="font-size:.82rem;color:var(--muted);">No pending disputes or unconfirmed payments.</div>
  </div>
}

<!-- Disputes requiring admin action -->
@if (flagged.Any())
{
  <div class="pv-card">
    <div class="pv-card-head">
      <span><i class="bi bi-exclamation-triangle-fill" style="color:var(--red);margin-right:.4rem;"></i> Disputes Requiring Review</span>
      <span class="pv-badge pvb-flagged">@flagged.Count Active</span>
    </div>
    <div style="overflow-x:auto;">
      <div class="pv-row">
        <div class="pv-col-hd">#</div>
        <div class="pv-col-hd">Customer</div>
        <div class="pv-col-hd">Shop / Mechanic</div>
        <div class="pv-col-hd">Mechanic Said</div>
        <div class="pv-col-hd">Customer Said</div>
        <div class="pv-col-hd">Difference</div>
        <div class="pv-col-hd">Status</div>
        <div class="pv-col-hd">Action</div>
      </div>
      @foreach (var v in flagged)
      {
        var diff = (v.CustomerConfirmedAmount ?? 0) - v.MechanicReportedAmount;
        <div class="pv-row">
          <div><div class="pv-id">#@v.ServiceRequestId</div></div>
          <div>
            <div class="pv-name">@(v.ServiceRequest?.Customer?.FullName ?? "—")</div>
            <div class="pv-sub">@(v.ServiceRequest?.Customer?.PhoneNumber ?? "")</div>
          </div>
          <div>
            <div class="pv-name">@(v.ServiceRequest?.Shop?.ShopName ?? "—")</div>
            <div class="pv-sub"><i class="bi bi-wrench" style="font-size:.65rem;"></i> @(v.ServiceRequest?.Mechanic?.FullName ?? "—")</div>
          </div>
          <div><span class="pv-amt pv-amt-green">@v.MechanicReportedAmount.ToString("F2") JOD</span></div>
          <div>
            @if (v.CustomerConfirmedAmount.HasValue)
            { <span class="pv-amt pv-amt-red">@v.CustomerConfirmedAmount.Value.ToString("F2") JOD</span> }
            else { <span class="pv-sub">—</span> }
          </div>
          <div>
            @if (v.CustomerConfirmedAmount.HasValue)
            {
              <span class="pv-diff @(diff > 0 ? "pv-diff-neg" : "pv-diff-pos")">
                @(diff > 0 ? "+" : "")@diff.ToString("F2") JOD
              </span>
            }
          </div>
          <div><span class="pv-badge pvb-flagged">@v.Status</span></div>
          <div class="pv-col-actions">
            <button type="button" class="btn-jaa btn-primary btn-sm"
                    onclick="openResolve(@v.Id, @v.ServiceRequestId, '@(v.ServiceRequest?.Customer?.FullName)', @v.MechanicReportedAmount.ToString("F2", System.Globalization.CultureInfo.InvariantCulture), @((v.CustomerConfirmedAmount ?? 0).ToString("F2", System.Globalization.CultureInfo.InvariantCulture)))">
              <i class="bi bi-gavel"></i> Resolve
            </button>
          </div>
        </div>
      }
    </div>
  </div>
}

<!-- Pending customer confirmation -->
@if (pending.Any())
{
  <div class="pv-card">
    <div class="pv-card-head">
      <span><i class="bi bi-hourglass-split" style="color:var(--yellow-t);margin-right:.4rem;"></i> Awaiting Customer Confirmation</span>
      <span class="pv-badge pvb-pending">@pending.Count</span>
    </div>
    <div style="overflow-x:auto;">
      <div class="pv-row" style="grid-template-columns:60px 1fr 1fr 120px 1fr;">
        <div class="pv-col-hd">#</div>
        <div class="pv-col-hd">Customer</div>
        <div class="pv-col-hd">Shop / Mechanic</div>
        <div class="pv-col-hd">Mechanic Reported</div>
        <div class="pv-col-hd">Reported At</div>
      </div>
      @foreach (var v in pending)
      {
        <div class="pv-row" style="grid-template-columns:60px 1fr 1fr 120px 1fr;">
          <div><div class="pv-id">#@v.ServiceRequestId</div></div>
          <div>
            <div class="pv-name">@(v.ServiceRequest?.Customer?.FullName ?? "—")</div>
            <div class="pv-sub">@(v.ServiceRequest?.Customer?.PhoneNumber ?? "")</div>
          </div>
          <div>
            <div class="pv-name">@(v.ServiceRequest?.Shop?.ShopName ?? "—")</div>
            <div class="pv-sub"><i class="bi bi-wrench" style="font-size:.65rem;"></i> @(v.ServiceRequest?.Mechanic?.FullName ?? "—")</div>
          </div>
          <div><span class="pv-amt pv-amt-green">@v.MechanicReportedAmount.ToString("F2") JOD</span></div>
          <div class="pv-sub">@v.CreatedAt.ToLocalTime().ToString("d MMM yyyy, h:mm tt")</div>
        </div>
      }
    </div>
  </div>
}

<!-- Resolved -->
@if (resolved.Any() || verified.Any())
{
  <div class="pv-card">
    <div class="pv-card-head">
      <span><i class="bi bi-check2-all" style="color:var(--green-t);margin-right:.4rem;"></i> Verified &amp; Resolved</span>
    </div>
    <div style="overflow-x:auto;">
      <div class="pv-row" style="grid-template-columns:60px 1fr 1fr 110px 110px 120px;">
        <div class="pv-col-hd">#</div>
        <div class="pv-col-hd">Customer</div>
        <div class="pv-col-hd">Shop</div>
        <div class="pv-col-hd">Reported</div>
        <div class="pv-col-hd">Final</div>
        <div class="pv-col-hd">Status</div>
      </div>
      @foreach (var v in resolved.Concat(verified))
      {
        <div class="pv-row" style="grid-template-columns:60px 1fr 1fr 110px 110px 120px;">
          <div><div class="pv-id">#@v.ServiceRequestId</div></div>
          <div><div class="pv-name">@(v.ServiceRequest?.Customer?.FullName ?? "—")</div></div>
          <div><div class="pv-name">@(v.ServiceRequest?.Shop?.ShopName ?? "—")</div></div>
          <div class="pv-sub">@v.MechanicReportedAmount.ToString("F2") JOD</div>
          <div><span class="pv-amt pv-amt-blue">@((v.FinalApprovedAmount ?? v.MechanicReportedAmount).ToString("F2")) JOD</span></div>
          <div><span class="pv-badge @(v.Status == VerificationStatus.Verified ? "pvb-verified" : "pvb-resolved")">@v.Status</span></div>
        </div>
      }
    </div>
  </div>
}

<!-- Resolve Modal -->
<div class="pv-modal-overlay" id="resolveModal" onclick="if(event.target===this)closeResolve()">
  <div class="pv-modal">
    <div class="pv-modal-title"><i class="bi bi-gavel me-2" style="color:var(--red);"></i>Resolve Dispute — Request #<span id="mdReqId"></span></div>

    <div class="pv-modal-row"><span class="pv-modal-lbl">Customer</span><span class="pv-modal-val" id="mdCust">—</span></div>
    <div class="pv-modal-row"><span class="pv-modal-lbl">Mechanic Reported</span><span class="pv-modal-val pv-amt-green" id="mdMech">—</span></div>
    <div class="pv-modal-row"><span class="pv-modal-lbl">Customer Confirmed</span><span class="pv-modal-val pv-amt-red" id="mdCust2">—</span></div>

    <form asp-action="ResolveVerification" method="post" id="resolveForm">
      @Html.AntiForgeryToken()
      <input type="hidden" name="verificationId" id="mdVerId" />

      <div class="pv-res-opts">
        <label class="pv-res-opt">
          <input type="radio" name="resolution" value="mechanic" checked />
          <div>
            <div class="pv-res-opt-label">Approve Mechanic Amount</div>
            <div class="pv-res-opt-sub" id="mdMechLbl">Use the amount the mechanic reported</div>
          </div>
        </label>
        <label class="pv-res-opt">
          <input type="radio" name="resolution" value="customer" />
          <div>
            <div class="pv-res-opt-label">Approve Customer Amount</div>
            <div class="pv-res-opt-sub" id="mdCustLbl">Use the amount the customer confirmed</div>
          </div>
        </label>
        <label class="pv-res-opt">
          <input type="radio" name="resolution" value="manual" onchange="document.getElementById('mdManualField').style.display='block'" />
          <div style="flex:1;">
            <div class="pv-res-opt-label">Manually Set Final Amount</div>
            <div class="pv-res-opt-sub">Enter a custom final amount</div>
            <div class="pv-manual-field" id="mdManualField">
              <input type="number" name="finalAmount" step="0.01" min="0.01" class="pv-manual-in" placeholder="Final amount in JOD" />
            </div>
          </div>
        </label>
      </div>

      <textarea name="adminNotes" class="pv-notes-in" rows="2" placeholder="Admin notes (optional)..."></textarea>

      <div class="pv-modal-actions">
        <button type="button" class="btn-pv-close" onclick="closeResolve()"><i class="bi bi-x-lg"></i> Cancel</button>
        <button type="submit" class="btn-pv-resolve"><i class="bi bi-check-circle-fill"></i> Confirm Resolution</button>
      </div>
    </form>
  </div>
</div>

@section Scripts {
<script>
function openResolve(verId, reqId, custName, mechAmt, custAmt) {
  document.getElementById('mdVerId').value   = verId;
  document.getElementById('mdReqId').textContent = reqId;
  document.getElementById('mdCust').textContent  = custName;
  document.getElementById('mdMech').textContent  = mechAmt + ' JOD';
  document.getElementById('mdCust2').textContent = custAmt + ' JOD';
  document.getElementById('mdMechLbl').textContent = mechAmt + ' JOD';
  document.getElementById('mdCustLbl').textContent = custAmt + ' JOD';
  document.getElementById('mdManualField').style.display = 'none';
  document.querySelector('input[value="mechanic"]').checked = true;
  document.getElementById('resolveModal').classList.add('open');
}
function closeResolve() {
  document.getElementById('resolveModal').classList.remove('open');
}
document.querySelectorAll('input[name="resolution"]').forEach(r => {
  r.addEventListener('change', () => {
    document.getElementById('mdManualField').style.display =
      r.value === 'manual' ? 'block' : 'none';
  });
});
</script>
}
