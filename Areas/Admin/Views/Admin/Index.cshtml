@model JAA.ViewModels.AdminDashboardViewModel
@{ ViewData["Title"] = "Admin Dashboard"; ViewData["PageTitle"] = "Operations Dashboard"; ViewData["PageSub"] = $"Live overview · {DateTime.Now:dddd, d MMMM yyyy}"; }

<div class="row g-3 mb-4">
  @{ var stats = new[]{ ("bi-send-fill","stat-icon-red","Total Requests",Model.TotalRequests.ToString(),$"{Model.TotalRequests} all-time"), ("bi-hourglass-split","stat-icon-yellow","Active Now",Model.ActiveRequests.ToString(),"Currently in progress"), ("bi-shop-window","stat-icon-green","Shops",Model.TotalShops.ToString(),$"{Model.VerifiedShops} verified"), ("bi-people-fill","stat-icon-blue","Users",Model.TotalUsers.ToString(),$"{Model.TotalCustomers} customers"), }; }
  @foreach (var s in stats)
  { <div class="col-6 col-xl-3"><div class="stat-card"><div class="stat-icon @s.Item2"><i class="bi @s.Item1"></i></div><div><div class="stat-num">@s.Item4</div><div class="stat-label">@s.Item3</div></div></div></div> }
</div>

<div class="row g-3 mb-4">
  @foreach (var n in new[]{ ("Dashboard","bi-grid-fill",$"{Model.ActiveRequests} active","Overview"), ("Shops","bi-shop-window",$"{Model.TotalShops} shops","Verify & manage"), ("Requests","bi-list-ul",$"{Model.ActiveRequests} active","All requests"), ("Reports","bi-bar-chart-line-fill","Finance","Revenue reports"), })
  { <div class="col-6 col-lg"><a asp-area="Admin" asp-controller="Admin" asp-action="@n.Item1" class="card-jaa d-block" style="cursor:pointer;text-decoration:none;"><div style="width:40px;height:40px;background:rgba(230,57,70,.12);border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:15px;color:var(--red);margin-bottom:.8rem;"><i class="bi @n.Item2"></i></div><div style="font-size:.88rem;font-weight:700;color:var(--white);margin-bottom:.15rem;">@n.Item1</div><div class="fs-xs text-muted">@n.Item4</div><div style="font-size:.78rem;color:var(--red);font-weight:600;margin-top:.25rem;">@n.Item3</div></a></div> }
</div>

<div class="card-jaa" style="padding:0;overflow:hidden;">
  <div class="section-head" style="padding:1.2rem 1.5rem 0;">
    <h5>Live Active Requests <span style="display:inline-flex;align-items:center;gap:.3rem;font-size:.72rem;color:var(--muted);font-weight:400;margin-left:.5rem;"><span class="pulse-dot"></span> @Model.ActiveRequests active</span></h5>
    <a asp-area="Admin" asp-controller="Admin" asp-action="Requests" class="btn-jaa btn-outline btn-sm">View All</a>
  </div>
  <div style="overflow-x:auto;">
    <table class="table-jaa">
      <thead><tr><th style="padding-left:1.5rem;">ID</th><th>Customer</th><th>Shop</th><th>Situation</th><th>Status</th><th>Time</th></tr></thead>
      <tbody>
        @foreach (var r in Model.LiveRequests)
        { <tr><td class="td-primary" style="padding-left:1.5rem;">#@r.Id</td><td>@r.Customer?.FullName</td><td>@(r.Shop?.ShopName ?? "—")</td><td class="td-truncate">@r.SituationDescription</td><td><span class="badge-jaa badge-@r.Status.ToString().ToLower()">@r.Status</span></td><td class="td-muted">@r.CreatedAt.ToLocalTime().ToString("HH:mm")</td></tr> }
        @if (!Model.LiveRequests.Any()) { <tr><td colspan="6" style="text-align:center;padding:1.5rem;color:var(--muted);">No active requests.</td></tr> }
      </tbody>
    </table>
  </div>
</div>
