@model List<JAA.Models.RepairShop>
@{ ViewData["Title"] = "Shops"; ViewData["PageTitle"] = "Manage Shops"; ViewData["PageSub"] = $"{Model.Count} shop(s)"; }

<div class="card-jaa mb-4">
  <form method="get" class="d-flex gap-3">
    <div class="search-box flex-grow-1"><i class="bi bi-search"></i><input type="text" name="search" value="@ViewBag.Search" class="search-input" style="width:100%;" placeholder="@L["Adm.SearchNameCity"].Value" /></div>
    <button type="submit" class="btn-jaa btn-outline btn-sm"><i class="bi bi-funnel-fill"></i></button>
  </form>
</div>
<div class="card-jaa" style="padding:0;overflow:hidden;">
  <div style="overflow-x:auto;">
    <table class="table-jaa">
      <thead><tr><th style="padding-left:1.5rem;">@L["Adm.Shop"]</th><th>@L["Adm.Owner"]</th><th>@L["Adm.City"]</th><th>@L["Adm.Jobs"]</th><th>@L["Adm.Rating"]</th><th>@L["Adm.Verified"]</th><th style="padding-right:1.5rem;">@L["Adm.Action"]</th></tr></thead>
      <tbody>
        @foreach (var s in Model)
        { var avg = s.Feedbacks.Any() ? s.Feedbacks.Average(f=>f.Rating) : 0;
          <tr>
            <td style="padding-left:1.5rem;"><div style="display:flex;align-items:center;gap:.7rem;"><div style="width:34px;height:34px;border-radius:50%;background:rgba(230,57,70,.12);border:2px solid rgba(230,57,70,.2);display:flex;align-items:center;justify-content:center;font-size:.75rem;font-weight:700;color:var(--red);flex-shrink:0;">@s.ShopName.Substring(0,2).ToUpper()</div><div class="td-primary">@s.ShopName</div></div></td>
            <td>@s.Owner?.FullName</td><td>@s.City</td>
            <td>@s.ServiceRequests.Count(r=>r.Status==JAA.Models.RequestStatus.Completed)</td>
            <td>@(avg>0?$"{avg:F1} ★":"—")</td>
            <td>@if(s.IsVerified){<span class="badge-jaa badge-verified"><i class="bi bi-patch-check-fill"></i> @L["Adm.Verified"]</span>}else{<span class="badge-jaa badge-unverified"><i class="bi bi-hourglass-split"></i> @L["Adm.Pending"]</span>}</td>
            <td style="padding-right:1.5rem;">
              <form asp-area="Admin" asp-controller="Admin" asp-action="VerifyShop" asp-route-id="@s.Id" method="post" style="display:inline;">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn-jaa @(s.IsVerified?"btn-outline":"btn-green") btn-sm">@(s.IsVerified?L["Adm.Unverify"].Value:L["Adm.Verify"].Value)</button>
              </form>
            </td>
          </tr>
        }
        @if (!Model.Any()) { <tr><td colspan="7" style="text-align:center;padding:2rem;color:var(--muted);">@L["Adm.NoShopsFound"]</td></tr> }
      </tbody>
    </table>
  </div>
</div>
