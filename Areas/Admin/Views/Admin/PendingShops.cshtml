@model List<JAA.Models.RepairShop>
@{
    Layout = "_DashboardLayout";
    ViewData["Title"]    = "Pending Shops";
    ViewData["PageTitle"] = "Shop Approvals";
    ViewData["PageSub"]  = $"{Model.Count} shop(s) awaiting review";
}

@section Styles {
<style>
/* ── approval card ───────────────────────────────────────── */
.apv-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 16px;
    overflow: hidden;
    transition: border-color .2s, box-shadow .2s;
}
.apv-card:hover { border-color: rgba(230,57,70,.2); box-shadow: 0 8px 32px rgba(0,0,0,.35); }

/* top accent bar */
.apv-bar { height: 3px; background: linear-gradient(90deg,#e63946,rgba(230,57,70,.3)); }

/* header row */
.apv-header { display:flex; align-items:flex-start; gap:1rem; padding:1.4rem 1.4rem .9rem; }

.apv-avatar {
    width: 52px; height: 52px; border-radius: 14px; flex-shrink: 0;
    background: rgba(230,57,70,.12); border: 2px solid rgba(230,57,70,.2);
    display: flex; align-items: center; justify-content: center;
    font-size: 1.15rem; font-weight: 800; color: var(--red); letter-spacing:-.5px;
}

.apv-name { font-size: 1.05rem; font-weight: 800; color: var(--white); line-height: 1.2; }
.apv-status { display:inline-flex;align-items:center;gap:.3rem;padding:.2rem .65rem;border-radius:999px;font-size:.62rem;font-weight:700;letter-spacing:.03em;background:rgba(245,158,11,.12);color:#d97706;border:1px solid rgba(245,158,11,.2); }

/* info grid */
.apv-info {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(200px,1fr));
    gap:.6rem; padding: 0 1.4rem .9rem;
}
.apv-info-item { display:flex; align-items:center; gap:.55rem; }
.apv-info-icon {
    width:30px;height:30px;border-radius:8px;flex-shrink:0;
    background:rgba(255,255,255,.04);border:1px solid var(--border);
    display:flex;align-items:center;justify-content:center;
    font-size:.72rem;color:var(--muted);
}
.apv-info-label { font-size:.65rem;color:var(--muted);line-height:1; }
.apv-info-val   { font-size:.8rem;color:var(--light);font-weight:600;line-height:1.3; }

/* divider */
.apv-divider { border:none;border-top:1px solid var(--border);margin:0 1.4rem; }

/* footer row */
.apv-footer { display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:.75rem; padding:.9rem 1.4rem; }
.apv-meta   { font-size:.72rem; color:var(--muted); display:flex;align-items:center;gap:.5rem;flex-wrap:wrap; }
.apv-meta strong { color:var(--text2); font-weight:600; }

/* actions */
.apv-actions { display:flex; align-items:center; gap:.6rem; flex-wrap:wrap; }

.btn-approve {
    display:inline-flex;align-items:center;gap:.4rem;
    background:var(--green-t,#3fb950);border:none;border-radius:9px;
    color:#fff;font-size:.8rem;font-weight:700;font-family:var(--font);
    padding:.55rem 1.1rem;cursor:pointer;transition:all .18s;
    white-space:nowrap;
}
.btn-approve:hover { opacity:.88; transform:translateY(-1px); }

.btn-cert {
    display:inline-flex;align-items:center;gap:.4rem;
    background:rgba(88,166,255,.08);border:1px solid rgba(88,166,255,.18);
    border-radius:9px;color:var(--blue,#58a6ff);font-size:.78rem;font-weight:600;
    font-family:var(--font);padding:.52rem 1rem;cursor:pointer;
    text-decoration:none;transition:all .18s;white-space:nowrap;
}
.btn-cert:hover { background:rgba(88,166,255,.14); color:var(--blue,#58a6ff); }

.btn-reject-toggle {
    display:inline-flex;align-items:center;gap:.4rem;
    background:rgba(230,57,70,.06);border:1px solid rgba(230,57,70,.18);
    border-radius:9px;color:var(--red);font-size:.78rem;font-weight:600;
    font-family:var(--font);padding:.52rem 1rem;cursor:pointer;
    transition:all .18s;white-space:nowrap;
}
.btn-reject-toggle:hover { background:rgba(230,57,70,.12); }

/* reject panel */
.reject-panel {
    display:none; background:rgba(230,57,70,.04);
    border-top:1px solid rgba(230,57,70,.12); padding:1rem 1.4rem;
}
.reject-panel.open { display:block; }
.reject-panel label { font-size:.73rem;color:var(--muted);font-weight:600;display:block;margin-bottom:.45rem; }
.reject-row { display:flex;gap:.6rem;align-items:stretch; }
.reject-input {
    flex:1;background:rgba(255,255,255,.04);border:1px solid rgba(230,57,70,.22);
    border-radius:9px;color:var(--light);font-size:.8rem;font-family:var(--font);
    padding:.55rem .85rem;outline:none;transition:border-color .2s;
}
.reject-input:focus { border-color:var(--red); }
.reject-input::placeholder { color:rgba(255,255,255,.2); }
.btn-reject-submit {
    display:inline-flex;align-items:center;gap:.35rem;
    background:var(--red);border:none;border-radius:9px;
    color:#fff;font-size:.78rem;font-weight:700;font-family:var(--font);
    padding:.55rem .95rem;cursor:pointer;transition:all .18s;white-space:nowrap;
}
.btn-reject-submit:hover { background:var(--red-d,#c1121f); }

/* empty state */
.apv-empty {
    text-align:center;padding:4rem 1.5rem;background:var(--card);
    border:1px solid var(--border);border-radius:16px;
}
.apv-empty-icon { font-size:3rem;opacity:.2;display:block;margin-bottom:1rem; }

/* no-cert warning */
.no-cert-warn {
    display:inline-flex;align-items:center;gap:.35rem;
    font-size:.7rem;color:rgba(245,158,11,.75);margin-top:.3rem;
}

/* count chip in page header */
.count-chip {
    display:inline-flex;align-items:center;justify-content:center;
    background:rgba(230,57,70,.12);border:1px solid rgba(230,57,70,.2);
    color:var(--red);border-radius:999px;font-size:.7rem;font-weight:700;
    padding:.1rem .55rem;margin-left:.5rem;
}
</style>
}

@if (!Model.Any())
{
    <div class="apv-empty">
        <i class="bi bi-shop-window apv-empty-icon"></i>
        <h5 style="color:var(--white);margin-bottom:.4rem;">@L["APS.NoPendingShops"]</h5>
        <p style="color:var(--muted);font-size:.85rem;margin:0;">@L["APS.AllReviewed"]</p>
    </div>
}
else
{
    <div class="d-flex flex-column gap-3">
      @foreach (var shop in Model)
      {
        var initials = shop.ShopName.Length >= 2 ? shop.ShopName.Substring(0,2).ToUpper() : shop.ShopName.ToUpper();
        var submittedDate = shop.CreatedAt.ToLocalTime().ToString("dd MMM yyyy · HH:mm");

        <div class="apv-card">
          <div class="apv-bar"></div>

          <!-- Header -->
          <div class="apv-header">
            <div class="apv-avatar">@initials</div>
            <div style="flex:1;min-width:0;">
              <div style="display:flex;align-items:center;gap:.6rem;flex-wrap:wrap;margin-bottom:.3rem;">
                <span class="apv-name">@shop.ShopName</span>
                <span class="apv-status"><i class="bi bi-hourglass-split" style="font-size:.6rem;"></i> @L["Adm.Pending"]</span>
              </div>
              @if (!string.IsNullOrWhiteSpace(shop.Description))
              {
                <p style="font-size:.78rem;color:var(--muted);margin:0;line-height:1.5;">@shop.Description</p>
              }
            </div>
          </div>

          <!-- Info grid -->
          <div class="apv-info">
            <div class="apv-info-item">
              <div class="apv-info-icon"><i class="bi bi-person-fill"></i></div>
              <div><div class="apv-info-label">Owner</div><div class="apv-info-val">@(shop.OwnerName ?? shop.Owner?.FullName ?? "—")</div></div>
            </div>
            <div class="apv-info-item">
              <div class="apv-info-icon"><i class="bi bi-geo-alt-fill"></i></div>
              <div><div class="apv-info-label">City</div><div class="apv-info-val">@shop.City</div></div>
            </div>
            <div class="apv-info-item">
              <div class="apv-info-icon"><i class="bi bi-map-fill"></i></div>
              <div><div class="apv-info-label">Address</div><div class="apv-info-val">@shop.Address</div></div>
            </div>
            <div class="apv-info-item">
              <div class="apv-info-icon"><i class="bi bi-telephone-fill"></i></div>
              <div><div class="apv-info-label">Phone</div><div class="apv-info-val">@(shop.PhoneNumber ?? "—")</div></div>
            </div>
            @if (!string.IsNullOrEmpty(shop.Owner?.Email))
            {
            <div class="apv-info-item">
              <div class="apv-info-icon"><i class="bi bi-envelope-fill"></i></div>
              <div><div class="apv-info-label">Email</div><div class="apv-info-val" style="font-size:.74rem;">@shop.Owner.Email</div></div>
            </div>
            }
            <div class="apv-info-item">
              <div class="apv-info-icon"><i class="bi bi-calendar3"></i></div>
              <div><div class="apv-info-label">Submitted</div><div class="apv-info-val">@submittedDate</div></div>
            </div>
          </div>

          <hr class="apv-divider" />

          <!-- Footer: cert link + actions -->
          <div class="apv-footer">
            <div class="apv-meta">
              @if (!string.IsNullOrEmpty(shop.BusinessCertificateUrl))
              {
                <a asp-action="ViewCertificate" asp-route-shopId="@shop.Id" class="btn-cert" target="_blank">
                  <i class="bi bi-file-earmark-pdf-fill"></i> @L["APS.ViewCertificate"]
                </a>
              }
              else
              {
                <span class="no-cert-warn"><i class="bi bi-exclamation-triangle-fill"></i> @L["APS.NoCertificate"]</span>
              }
            </div>

            <div class="apv-actions">
              <!-- Approve -->
              <form asp-action="ApproveShop" method="post" style="margin:0;">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@shop.Id" />
                <button type="submit" class="btn-approve">
                  <i class="bi bi-check-circle-fill"></i> @L["APS.ApproveShop"]
                </button>
              </form>

              <!-- Reject toggle -->
              <button type="button" class="btn-reject-toggle"
                      onclick="toggleReject('@shop.Id')">
                <i class="bi bi-x-circle-fill"></i> @L["Adm.Reject"]
              </button>
            </div>
          </div>

          <!-- Reject panel (hidden until toggled) -->
          <div class="reject-panel" id="reject-panel-@shop.Id">
            <form asp-action="RejectShop" method="post">
              @Html.AntiForgeryToken()
              <input type="hidden" name="id" value="@shop.Id" />
              <label>@L["APS.RejectionReason"] <span style="font-weight:400;opacity:.6;">(optional)</span></label>
              <div class="reject-row">
                <input type="text" name="reason" class="reject-input"
                       placeholder="@L["APS.RejectionReason"].Value" />
                <button type="submit" class="btn-reject-submit">
                  <i class="bi bi-x-lg"></i> Confirm Rejection
                </button>
              </div>
            </form>
          </div>

        </div><!-- /apv-card -->
      }
    </div>
}

@section Scripts {
<script>
function toggleReject(shopId) {
    const panel = document.getElementById('reject-panel-' + shopId);
    panel.classList.toggle('open');
}
</script>
}
